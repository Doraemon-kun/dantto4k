<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!-- Suppress warnings that cause build failures on Japanese Windows (CP932):
       - /wd4819 : suppress "file contains character not representable in current code page"
                  (tsduck UTF-8 source files and Windows SDK headers with non-ASCII chars)
       - /Wv:17  : limit active warnings to those that existed in VS 2022,
                  preventing new SDK 10.0.28000.0+ headers from triggering new warnings -->
  <ItemDefinitionGroup>
    <ClCompile>
      <AdditionalOptions>/wd4819 /Wv:17 %(AdditionalOptions)</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
